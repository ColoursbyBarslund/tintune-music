---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tintune Music Lab</title>

    <style>
      :root {
        --bg: #F6F4EB;
        --panel: #121212;
        --border: rgba(255, 255, 255, 0.12);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.62);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
          "Apple Color Emoji", "Segoe UI Emoji";
        background: var(--bg);
        color: var(--text);
      }

      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 32px 40px 56px;
      }

      header {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 22px;
      }

      h1 {
        margin: 0;
        font-size: 28px;
        letter-spacing: 0.2px;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.35;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 18px;
      }

      .visualizerPanel {
        background: transparent;
        border: none;
        padding: 0;
        width: calc(100% - 36px);
        margin-left: auto;
        margin-right: auto;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        min-height: calc(100dvh - 88px);
        align-items: center;
      }

      .paletteRow {
        display: grid;
        gap: 12px;
      }

      .wheelStage {
        --overlay-x: 40px;
        --overlay-bottom: 40px;
        --overlay-height: 94px;
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 5;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid transparent;
        background: transparent;
      }

      #colorWheel {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        z-index: 1;
      }

      .visualizerLayer {
        position: absolute;
        inset: 0;
        border-radius: 14px;
        overflow: hidden;
        pointer-events: none;
        z-index: 2;
      }

      .visualizerCard {
        position: absolute;
        left: var(--overlay-x);
        right: var(--overlay-x);
        bottom: var(--overlay-bottom);
        height: var(--overlay-height);
        border-radius: 16px;
        background: #F6F4EB;
        box-shadow: 0 18px 34px rgba(0, 0, 0, 0.28);
        pointer-events: none;
        z-index: 2;
      }

      .visualizerActions {
        position: absolute;
        left: var(--overlay-x);
        right: var(--overlay-x);
        bottom: var(--overlay-bottom);
        height: var(--overlay-height);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 14px;
        padding: 11px 14px 12px;
        z-index: 3;
        pointer-events: none;
      }

      .overlayPaletteBar {
        width: 100%;
        height: 12px;
        border-radius: 999px;
        border: 1px solid rgba(0, 0, 0, 0.16);
        overflow: hidden;
        display: flex;
        background: rgba(0, 0, 0, 0.06);
      }

      .overlayPaletteBar > div {
        height: 100%;
        flex: 0 0 auto;
      }

      .overlayButtons {
        display: flex;
        align-items: center;
        gap: 10px;
        pointer-events: none;
      }

      .overlayControlsRow {
        width: 100%;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
      }

      .overlayEngineWrap {
        justify-self: start;
        align-self: end;
        padding-bottom: 0;
        transform: translateY(8px);
      }

      .overlayButtons {
        justify-self: center;
      }

      .overlayControlsRow .engineBadge {
        color: #111111;
        border: none;
        background: transparent;
        border-radius: 0;
        padding: 0;
        font-size: 9px;
      }

      .overlayButtons button {
        pointer-events: auto;
        background: transparent;
        color: #111111;
        border: none;
        border-radius: 0;
        box-shadow: none;
        min-width: 0;
        padding: 6px 8px;
        font-size: 28px;
        line-height: 1;
      }

      .overlayButtons button:hover {
        background: transparent;
        opacity: 0.72;
      }

      .payloadToggleBtn {
        position: absolute;
        right: calc(var(--overlay-x) + 0px);
        bottom: calc(var(--overlay-bottom) - 2px);
        pointer-events: auto;
        background: transparent;
        color: #111111;
        border: none;
        border-radius: 0;
        box-shadow: none;
        width: 44px;
        height: 44px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        line-height: 1;
        cursor: pointer;
        z-index: 4;
      }

      .payloadToggleBtn:hover {
        background: transparent;
        opacity: 0.72;
      }

      .payloadToggleBtn[aria-pressed="true"] {
        opacity: 0.55;
      }

      #visualizerCanvas {
        width: 100%;
        height: 100%;
        display: block;
      }

      .visualizerSpinner {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 20px;
        height: 20px;
        margin-left: -10px;
        margin-top: -10px;
        border-radius: 999px;
        border: 2px solid rgba(255, 255, 255, 0.28);
        border-top-color: #fff;
        opacity: 0;
        pointer-events: none;
        z-index: 5;
        animation: spin 0.75s linear infinite;
        transition: opacity 140ms ease;
      }

      .visualizerSpinner.on {
        opacity: 1;
      }

      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .wheelDot {
        position: absolute;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: none;
        background: transparent;
        transform: translate(-50%, -50%);
        cursor: grab;
        box-shadow: none;
        z-index: 10;
      }

      .wheelDot::after {
        content: "";
        position: absolute;
        left: 50%;
        top: 50%;
        width: 16px;
        height: 16px;
        border-radius: 999px;
        border: 2px solid #fff;
        background: var(--dot-color, #888888);
        transform: translate(-50%, -50%);
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.35);
      }

      .wheelDot:active {
        cursor: grabbing;
      }

      .wheelDot.off {
        opacity: 0.35;
      }

      .wheelDot.off .dotRole {
        opacity: 0.35;
      }

      .dotRole {
        position: absolute;
        top: -4px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 9px;
        line-height: 1;
        color: #0b0b0b;
        white-space: nowrap;
        pointer-events: none;
        background: rgba(255, 255, 255, 0.85);
        border-radius: 999px;
        padding: 2px 5px;
      }

      .hexPopup {
        position: fixed;
        z-index: 20;
        display: none;
        padding: 0;
        border-radius: 10px;
        background: rgba(0, 0, 0, 0.78);
        border: none;
      }

      .hexPopup input {
        width: 116px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.25);
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        padding: 7px 9px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
      }

      .hexPopup input:focus,
      .hexPopup input:focus-visible {
        outline: none;
        box-shadow: none;
      }

      .controls {
        display: grid;
        gap: 14px;
        margin-top: 14px;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
        align-items: center;
      }

      button {
        appearance: none;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.08);
        color: var(--text);
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 14px;
        cursor: pointer;
      }

      button:hover {
        background: rgba(255, 255, 255, 0.12);
      }

      button.primary {
        background: rgba(255, 255, 255, 0.16);
      }

      audio {
        width: 100%;
        max-width: 100%;
        display: block;
      }

      .toggle {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted);
        font-size: 13px;
        user-select: none;
      }

      .status {
        margin-top: 10px;
        font-size: 13px;
        color: var(--muted);
        min-height: 18px;
      }

      .notice {
        display: none;
        margin-top: 10px;
        border: 1px solid rgba(255, 120, 120, 0.35);
        background: rgba(255, 120, 120, 0.08);
        border-radius: 10px;
        padding: 10px 12px;
        font-size: 13px;
        line-height: 1.35;
        color: #ffd7d7;
      }

      .notice a {
        color: #ffffff;
        text-underline-offset: 2px;
      }

      .engineWrap {
        margin-top: 8px;
      }

      .engineBadge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        color: var(--text);
        background: rgba(255, 255, 255, 0.06);
      }

      .hint {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.4;
      }

      .preview {
        display: grid;
        gap: 12px;
        margin-top: 14px;
        width: calc(100% - 36px);
        margin-left: auto;
        margin-right: auto;
      }

      #payloadPanel[hidden] {
        display: none !important;
      }

      .bar {
        height: 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        overflow: hidden;
        display: flex;
      }

      .bar > div {
        height: 100%;
        flex: 0 0 auto;
      }

      .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        color: var(--muted);
        line-height: 1.35;
        word-break: break-word;
      }

      .divider {
        height: 1px;
        background: var(--border);
        margin: 14px 0;
      }

      .hairline {
        height: 1px;
        background: var(--border);
        margin: 8px 0;
      }

      @media (max-width: 700px) {
        main {
          padding: 20px 16px 40px;
        }

        .grid {
          min-height: calc(100dvh - 60px);
        }

        .panel {
          padding: 14px;
        }

        .visualizerPanel {
          width: calc(100% - 28px);
        }

        .preview {
          width: calc(100% - 28px);
        }

        .wheelStage {
          --overlay-x: 16px;
          --overlay-bottom: 16px;
          --overlay-height: 86px;
        }

        .visualizerActions {
          gap: 8px;
          padding: 8px 10px 10px;
        }

        .overlayEngineWrap {
          padding-bottom: 0;
          transform: translateY(6px);
        }

        .overlayButtons {
          gap: 8px;
        }

        .overlayPaletteBar {
          height: 10px;
        }

        .overlayButtons button {
          flex: 1 1 0;
          min-width: 0;
          padding: 10px 10px;
          font-size: 13px;
        }

        .payloadToggleBtn {
          right: calc(var(--overlay-x) - 2px);
          bottom: calc(var(--overlay-bottom) - 4px);
        }
      }
    </style>
  </head>

  <body>
    <main>
      <div class="grid">
        <section class="panel visualizerPanel">
          <div class="paletteRow" aria-label="Palette">
            <div class="wheelStage" id="wheelStage">
              <canvas id="colorWheel"></canvas>
              <div class="visualizerLayer" id="visualizerLayer">
                <canvas id="visualizerCanvas"></canvas>
              </div>
              <div class="visualizerCard" aria-hidden="true"></div>
              <div class="visualizerActions" aria-label="Stream actions">
                <div class="overlayPaletteBar" aria-hidden="true">
                  <div id="p1"></div>
                  <div id="p2"></div>
                  <div id="p3"></div>
                </div>
                <div class="overlayControlsRow">
                  <div class="overlayEngineWrap">
                    <span class="engineBadge" id="engineBadge">Engine: Idle</span>
                  </div>
                  <div class="overlayButtons">
                    <button class="primary" id="generate" aria-label="Start or update stream" title="Start / Update stream">&#9654;</button>
                    <button id="stop" aria-label="Stop stream" title="Stop">&#9632;</button>
                  </div>
                  <div aria-hidden="true"></div>
                </div>
              </div>
              <button
                id="payloadToggleBtn"
                class="payloadToggleBtn"
                type="button"
                aria-label="Show or hide payload"
                aria-pressed="true"
                title="Show / hide payload"
              >&#9881;</button>
              <div class="visualizerSpinner" id="visualizerSpinner" aria-hidden="true"></div>

              <div class="wheelDot" id="dot0">
                <span class="dotRole">Base</span>
              </div>

              <div class="wheelDot" id="dot1">
                <span class="dotRole">Baggrund</span>
              </div>

              <div class="wheelDot" id="dot2">
                <span class="dotRole">Accent</span>
              </div>
            </div>

          </div>

          <div class="controls" aria-label="Controls">
            <div class="notice" id="notice"></div>
          </div>
        </section>
      </div>
      <aside class="panel preview" id="payloadPanel" hidden>
        <div id="payloadSection">
          <strong>Payload</strong>
          <div class="status" id="status"></div>
          <div class="hairline"></div>
          <audio id="player" preload="none" controls></audio>
          <audio id="playerB" preload="none" aria-hidden="true" style="display:none"></audio>
          <div class="divider"></div>
          <div class="mono" id="payload"></div>
        </div>

        <p class="hint">
          Stream is requested from <span class="mono">/api/mubert</span>. Playlist is auto-selected from ambient presets.
        </p>
      </aside>
      <div class="hexPopup" id="hexPopup">
        <input id="hexPopupInput" inputmode="text" autocapitalize="characters" />
      </div>

      <script>
        const $ = (id) => document.getElementById(id);

        const LS_CUSTOM_ID_KEY = "tintune_music_custom_id";

        function getOrCreateCustomId() {
          try {
            const existing = window.localStorage.getItem(LS_CUSTOM_ID_KEY);
            if (existing) return existing;
            const id = "tintune-music-" + Math.random().toString(16).slice(2) + "-" + Date.now().toString(16);
            window.localStorage.setItem(LS_CUSTOM_ID_KEY, id);
            return id;
          } catch {
            return "tintune-music-ephemeral";
          }
        }

        const state = {
          palette: ["#D0CAA9", "#37562A", "#7FAC9D"],
          enabled: [true, true, true],
        };
        const ROLE_NAMES = ["base", "background", "accent"];
        const ROLE_WEIGHTS = [60, 30, 10];
        const WHEEL_VALUE_GAMMA = 0.55;
        const WHEEL_SHAPE_POWER = 5;

        function clamp(n, min, max) {
          return Math.max(min, Math.min(max, n));
        }

        function normalizeHex(input) {
          const raw = String(input || "").trim();
          const hex = raw.startsWith("#") ? raw.slice(1) : raw;
          if (hex.length === 3) {
            const expanded = hex
              .split("")
              .map((c) => c + c)
              .join("");
            return "#" + expanded.toUpperCase();
          }
          if (hex.length !== 6) return null;
          if (!/^[0-9a-fA-F]{6}$/.test(hex)) return null;
          return "#" + hex.toUpperCase();
        }

        function hexToHsl(hex) {
          const norm = normalizeHex(hex);
          if (!norm) return null;
          const v = norm.slice(1);
          const r = parseInt(v.slice(0, 2), 16) / 255;
          const g = parseInt(v.slice(2, 4), 16) / 255;
          const b = parseInt(v.slice(4, 6), 16) / 255;
          const max = Math.max(r, g, b);
          const min = Math.min(r, g, b);
          const d = max - min;
          const l = (max + min) / 2;

          let h = 0;
          if (d !== 0) {
            if (max === r) h = ((g - b) / d) % 6;
            else if (max === g) h = (b - r) / d + 2;
            else h = (r - g) / d + 4;
            h *= 60;
            if (h < 0) h += 360;
          }
          const s = d === 0 ? 0 : d / (1 - Math.abs(2 * l - 1));
          return { h, s: s * 100, l: l * 100 };
        }

        function warmthFromHue(h) {
          const rad = (h * Math.PI) / 180;
          return Math.cos(rad); // warm>0 cool<0
        }

        function colorToSoundParams(hex) {
          const hsl = hexToHsl(hex) || { h: 180, s: 30, l: 50 };
          const warmth = warmthFromHue(hsl.h);

          const energy = clamp(
            18 + hsl.s * 0.45 + hsl.l * 0.18 + Math.max(0, warmth) * 16 - Math.max(0, -warmth) * 8,
            0,
            100
          );
          const texture = clamp(
            20 + hsl.s * 0.62 + Math.abs(50 - hsl.l) * 0.2,
            0,
            100
          );
          const space = clamp(
            42 + (100 - hsl.s) * 0.35 + Math.max(0, -warmth) * 18 + (50 - hsl.l) * 0.18,
            0,
            100
          );

          return {
            hex: normalizeHex(hex) || "#808080",
            energy: Math.round(energy),
            texture: Math.round(texture),
            space: Math.round(space),
          };
        }

        function deriveCombinedParams() {
          const active = state.palette
            .map((hex, idx) => ({
              role: ROLE_NAMES[idx],
              roleWeight: ROLE_WEIGHTS[idx],
              hex,
              enabled: state.enabled[idx],
            }))
            .filter((x) => x.enabled);

          const totalRoleWeight = active.reduce((a, c) => a + c.roleWeight, 0) || 1;
          const perColor = active.map((x, idx) => {
            const mapped = colorToSoundParams(x.hex);
            let weight = (x.roleWeight / totalRoleWeight) * 100;
            // Keep integer percentages while forcing exact 100 sum.
            if (idx === active.length - 1) {
              const used = active
                .slice(0, idx)
                .reduce((a, c2) => a + Math.floor((c2.roleWeight / totalRoleWeight) * 100), 0);
              weight = 100 - used;
            } else {
              weight = Math.floor(weight);
            }
            return {
              role: x.role,
              weight,
              ...mapped,
            };
          });

          const energyAvg = perColor.reduce((a, c) => a + c.energy * c.weight, 0) / 100;
          const textureAvg = perColor.reduce((a, c) => a + c.texture * c.weight, 0) / 100;
          const spaceAvg = perColor.reduce((a, c) => a + c.space * c.weight, 0) / 100;

          const hsls = perColor.map((c) => hexToHsl(c.hex)).filter(Boolean);
          const hueMin = hsls.length ? hsls.reduce((a, c) => Math.min(a, c.h), 360) : 0;
          const hueMax = hsls.length ? hsls.reduce((a, c) => Math.max(a, c.h), 0) : 0;
          const hueSpread = clamp(hueMax - hueMin, 0, 180);
          const diversity = hueSpread / 180;

          return {
            perColor,
            combined: {
              energy: Math.round(clamp(energyAvg + diversity * 6, 0, 100)),
              texture: Math.round(clamp(textureAvg + diversity * 12, 0, 100)),
              space: Math.round(clamp(spaceAvg + (1 - diversity) * 8, 0, 100)),
            },
          };
        }

        function deriveActivePalette() {
          return state.palette.filter((_, idx) => state.enabled[idx]);
        }

        function deriveNormalizedRoleWeights() {
          const activeIndices = ROLE_WEIGHTS
            .map((w, idx) => ({ w, idx, enabled: state.enabled[idx] }))
            .filter((x) => x.enabled);
          const total = activeIndices.reduce((a, c) => a + c.w, 0);
          if (!total) return [0, 0, 0];

          const out = [0, 0, 0];
          for (const x of activeIndices) {
            out[x.idx] = (x.w / total) * 100;
          }
          return out;
        }

        const wheel = {
          canvas: $("colorWheel"),
          stage: $("wheelStage"),
          visualizerLayer: $("visualizerLayer"),
          visualizerCanvas: $("visualizerCanvas"),
          spinner: $("visualizerSpinner"),
          dots: [$("dot0"), $("dot1"), $("dot2")],
          popup: $("hexPopup"),
          popupInput: $("hexPopupInput"),
          dragIndex: -1,
          editIndex: -1,
          hueSat: [
            { h: 0, s: 0 },
            { h: 0, s: 0 },
            { h: 0, s: 0 },
          ],
        };
        let visualizerRaf = 0;
        let visualizerEnergy = 40; // 0..100
        let visualizerIntensityTier = "low"; // low|medium|high
        let visualizerBusyCount = 0;

        function hexToRgb(hex) {
          const norm = normalizeHex(hex);
          if (!norm) return null;
          return {
            r: parseInt(norm.slice(1, 3), 16),
            g: parseInt(norm.slice(3, 5), 16),
            b: parseInt(norm.slice(5, 7), 16),
          };
        }

        function rgbToHsv(r, g, b) {
          const rn = r / 255;
          const gn = g / 255;
          const bn = b / 255;
          const max = Math.max(rn, gn, bn);
          const min = Math.min(rn, gn, bn);
          const d = max - min;
          let h = 0;
          if (d) {
            if (max === rn) h = ((gn - bn) / d) % 6;
            else if (max === gn) h = (bn - rn) / d + 2;
            else h = (rn - gn) / d + 4;
            h *= 60;
            if (h < 0) h += 360;
          }
          const s = max === 0 ? 0 : d / max;
          return { h, s: s * 100, v: max * 100 };
        }

        function hsvToRgb(h, s, v = 100) {
          const sn = clamp(s, 0, 100) / 100;
          const vn = clamp(v, 0, 100) / 100;
          const c = vn * sn;
          const hp = ((h % 360) + 360) % 360 / 60;
          const x = c * (1 - Math.abs((hp % 2) - 1));
          let r1 = 0; let g1 = 0; let b1 = 0;
          if (hp < 1) { r1 = c; g1 = x; }
          else if (hp < 2) { r1 = x; g1 = c; }
          else if (hp < 3) { g1 = c; b1 = x; }
          else if (hp < 4) { g1 = x; b1 = c; }
          else if (hp < 5) { r1 = x; b1 = c; }
          else { r1 = c; b1 = x; }
          const m = vn - c;
          return {
            r: Math.round((r1 + m) * 255),
            g: Math.round((g1 + m) * 255),
            b: Math.round((b1 + m) * 255),
          };
        }

        function rgbToHex(r, g, b) {
          const toHex = (n) => n.toString(16).padStart(2, "0").toUpperCase();
          return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
        }

        function mixHexColors(colors) {
          if (!colors.length) return "#000000";
          let r = 0; let g = 0; let b = 0;
          for (const c of colors) {
            const rgb = hexToRgb(c.hex);
            const w = (c.weight ?? 1);
            if (!rgb) continue;
            r += rgb.r * w;
            g += rgb.g * w;
            b += rgb.b * w;
          }
          const total = colors.reduce((a, c) => a + (c.weight ?? 1), 0) || 1;
          return rgbToHex(Math.round(r / total), Math.round(g / total), Math.round(b / total));
        }

        function hexWithAlpha(hex, alpha255) {
          const norm = normalizeHex(hex) || "#808080";
          const a = clamp(Math.round(alpha255), 0, 255).toString(16).padStart(2, "0").toUpperCase();
          return `${norm}${a}`;
        }

        function initWheelFromState() {
          state.palette.forEach((hex, idx) => {
            const rgb = hexToRgb(hex);
            if (!rgb) return;
            const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
            // In this wheel model, radius encodes darkness: center=white, edge=black.
            const v = clamp(hsv.v / 100, 0, 1);
            const sat = 1 - Math.pow(v, 1 / WHEEL_VALUE_GAMMA);
            wheel.hueSat[idx] = { h: hsv.h, s: clamp(sat * 100, 0, 100) };
          });
        }

        function wheelMetrics() {
          const rect = wheel.stage.getBoundingClientRect();
          const w = Math.max(1, Math.floor(rect.width));
          const h = Math.max(1, Math.floor(rect.height));
          const cx = w / 2;
          const cy = h / 2;
          const rx = w / 2;
          const ry = h / 2;
          return { rect, w, h, cx, cy, rx, ry };
        }

        function wheelNorm(nx, ny) {
          const p = WHEEL_SHAPE_POWER;
          return Math.pow(Math.pow(Math.abs(nx), p) + Math.pow(Math.abs(ny), p), 1 / p);
        }

        function wheelBoundaryScale(ux, uy) {
          const p = WHEEL_SHAPE_POWER;
          const denom = Math.pow(Math.pow(Math.abs(ux), p) + Math.pow(Math.abs(uy), p), 1 / p);
          if (!denom) return 1;
          return 1 / denom;
        }

        function drawWheel() {
          const { w, h, cx, cy, rx, ry } = wheelMetrics();
          wheel.canvas.width = w;
          wheel.canvas.height = h;
          const ctx = wheel.canvas.getContext("2d");
          ctx.setTransform(1, 0, 0, 1, 0, 0);

          const img = ctx.createImageData(w, h);
          const data = img.data;
          for (let y = 0; y < h; y++) {
            for (let x = 0; x < w; x++) {
              const nx = (x - cx) / rx;
              const ny = (y - cy) / ry;
              const sat = Math.min(1, wheelNorm(nx, ny));
              let hue = (Math.atan2(ny, nx) * 180) / Math.PI;
              if (hue < 0) hue += 360;
              const v = Math.pow(1 - sat, WHEEL_VALUE_GAMMA);
              const rgb = hsvToRgb(hue, sat * 100, v * 100);
              const i = (y * w + x) * 4;
              data[i] = rgb.r;
              data[i + 1] = rgb.g;
              data[i + 2] = rgb.b;
              data[i + 3] = 255;
            }
          }
          ctx.putImageData(img, 0, 0);
        }

        function resizeVisualizerCanvas() {
          const rect = wheel.visualizerLayer.getBoundingClientRect();
          const w = Math.max(1, Math.floor(rect.width));
          const h = Math.max(1, Math.floor(rect.height));
          wheel.visualizerCanvas.width = w;
          wheel.visualizerCanvas.height = h;
        }

        function drawVisualizerFrame(ms) {
          const ctx = wheel.visualizerCanvas.getContext("2d");
          const w = wheel.visualizerCanvas.width;
          const h = wheel.visualizerCanvas.height;
          if (!ctx || !w || !h) return;

          const drive = clamp(visualizerEnergy / 100, 0, 1);
          const tierBoost = visualizerIntensityTier === "high" ? 0.25 : visualizerIntensityTier === "medium" ? 0.12 : 0;
          const speed = 0.14 + drive * 0.95 + tierBoost;
          const t = ms * 0.001 * speed;
          ctx.clearRect(0, 0, w, h);

          const active = state.palette
            .map((hex, idx) => ({ hex, idx, enabled: state.enabled[idx], weight: ROLE_WEIGHTS[idx] }))
            .filter((x) => x.enabled);
          if (!active.length) return;

          // Fill entire visualizer and animate drifting fog-bands.
          const mixed = mixHexColors(active);
          ctx.fillStyle = mixed;
          ctx.fillRect(0, 0, w, h);

          const minDim = Math.min(w, h);
          const fogLayers = 5 + active.length;
          const blurPx = Math.round(minDim * (0.04 + drive * 0.03));
          const driftAmp = 0.16 + drive * 0.14;
          const driftLen = minDim * (0.85 + drive * 0.45);

          ctx.save();
          if (blurPx > 0) ctx.filter = `blur(${blurPx}px)`;
          ctx.globalCompositeOperation = "screen";
          for (let i = 0; i < fogLayers; i++) {
            const phase = i * 1.137;
            const angle = 0.2 + 0.08 * Math.sin(t * 0.11 + phase);
            const vx = Math.cos(angle);
            const vy = Math.sin(angle);
            const perpX = -vy;
            const perpY = vx;
            const flow = (Math.sin(t * (0.15 + i * 0.01) + phase) * 0.5 + 0.5) * driftLen;
            const sway = Math.sin(t * (0.31 + i * 0.015) + phase * 1.7) * minDim * driftAmp;
            const cx = w * 0.5 + vx * (flow - driftLen * 0.5) + perpX * sway;
            const cy = h * 0.5 + vy * (flow - driftLen * 0.5) + perpY * sway;

            const x1 = cx - vx * w * 1.4;
            const y1 = cy - vy * h * 1.4;
            const x2 = cx + vx * w * 1.4;
            const y2 = cy + vy * h * 1.4;
            const g = ctx.createLinearGradient(x1, y1, x2, y2);

            g.addColorStop(0, hexWithAlpha(mixed, 0));
            for (let k = 0; k < active.length; k++) {
              const c = active[(k + i) % active.length];
              const p = (k + 1) / (active.length + 1);
              const a = 34 + Math.round(drive * 42);
              g.addColorStop(Math.max(0, p - 0.11), hexWithAlpha(c.hex, 0));
              g.addColorStop(p, hexWithAlpha(c.hex, a));
              g.addColorStop(Math.min(1, p + 0.11), hexWithAlpha(c.hex, 0));
            }
            g.addColorStop(1, hexWithAlpha(mixed, 0));
            ctx.fillStyle = g;
            ctx.fillRect(-w * 0.25, -h * 0.25, w * 1.5, h * 1.5);
          }
          ctx.restore();

          // Slow depth haze to keep the mass cohesive.
          ctx.globalCompositeOperation = "soft-light";
          const haze = ctx.createRadialGradient(
            w * (0.5 + 0.18 * Math.sin(t * 0.23)),
            h * (0.5 + 0.18 * Math.cos(t * 0.19 + 0.8)),
            0,
            w * 0.5,
            h * 0.5,
            minDim * 1.05
          );
          haze.addColorStop(0, hexWithAlpha(mixed, 70));
          haze.addColorStop(0.72, hexWithAlpha(mixed, 18));
          haze.addColorStop(1, hexWithAlpha(mixed, 0));
          ctx.fillStyle = haze;
          ctx.fillRect(0, 0, w, h);

          const breathe = 0.06 + drive * 0.1;
          ctx.globalCompositeOperation = "overlay";
          ctx.fillStyle = `rgba(255,255,255,${breathe * (0.45 + 0.55 * Math.sin(t * 1.15))})`;
          ctx.fillRect(0, 0, w, h);
          ctx.globalCompositeOperation = "source-over";
        }

        function startVisualizerLoop() {
          const tick = (ms) => {
            drawVisualizerFrame(ms);
            visualizerRaf = requestAnimationFrame(tick);
          };
          if (visualizerRaf) cancelAnimationFrame(visualizerRaf);
          visualizerRaf = requestAnimationFrame(tick);
        }

        function rolePosition(idx) {
          const { cx, cy, rx, ry } = wheelMetrics();
          const hs = wheel.hueSat[idx];
          const rad = (hs.h * Math.PI) / 180;
          const sat = clamp(hs.s, 0, 100) / 100;
          const ux = Math.cos(rad);
          const uy = Math.sin(rad);
          const scale = wheelBoundaryScale(ux, uy);
          return {
            x: cx + ux * rx * scale * sat,
            y: cy + uy * ry * scale * sat,
          };
        }

        function updateDotVisuals() {
          for (let i = 0; i < 3; i++) {
            const dot = wheel.dots[i];
            const pos = rolePosition(i);
            dot.style.left = `${pos.x}px`;
            dot.style.top = `${pos.y}px`;
            dot.style.setProperty("--dot-color", state.palette[i]);
            dot.classList.toggle("off", !state.enabled[i]);
          }
        }

        function pointerToHueSat(clientX, clientY) {
          const { rect, cx, cy, rx, ry } = wheelMetrics();
          const x = clientX - rect.left;
          const y = clientY - rect.top;
          const nx = (x - cx) / rx;
          const ny = (y - cy) / ry;
          let h = (Math.atan2(ny, nx) * 180) / Math.PI;
          if (h < 0) h += 360;
          const s = clamp(wheelNorm(nx, ny) * 100, 0, 100);
          return { h, s };
        }

        function commitRoleColor(idx, hs, { triggerUpdate = true } = {}) {
          wheel.hueSat[idx] = { h: hs.h, s: hs.s };
          const sat = clamp(hs.s / 100, 0, 1);
          const v = Math.pow(1 - sat, WHEEL_VALUE_GAMMA);
          const rgb = hsvToRgb(hs.h, hs.s, v * 100);
          state.palette[idx] = rgbToHex(rgb.r, rgb.g, rgb.b);
          updateDotVisuals();
          render();
          if (triggerUpdate) scheduleLiveUpdate();
        }

        function hideHexPopup() {
          wheel.popup.style.display = "none";
          wheel.editIndex = -1;
        }

        function openHexPopup(idx, clientX, clientY) {
          wheel.editIndex = idx;
          wheel.popup.style.display = "block";
          wheel.popup.style.left = `${clientX + 8}px`;
          wheel.popup.style.top = `${clientY + 8}px`;
          wheel.popupInput.value = state.palette[idx];
          wheel.popupInput.focus();
          wheel.popupInput.select();
        }

        function setStatus(text) {
          $("status").textContent = text || "";
        }

        function setVisualizerBusy(on) {
          visualizerBusyCount += on ? 1 : -1;
          if (visualizerBusyCount < 0) visualizerBusyCount = 0;
          wheel.spinner.classList.toggle("on", visualizerBusyCount > 0);
        }

        function clearNotice() {
          const el = $("notice");
          el.style.display = "none";
          el.textContent = "";
        }

        function showNoticeWithLink(message, linkHref, linkLabel) {
          const el = $("notice");
          el.innerHTML = "";
          const msg = document.createElement("span");
          msg.textContent = `${message} `;
          const link = document.createElement("a");
          link.href = linkHref;
          link.target = "_blank";
          link.rel = "noopener noreferrer";
          link.textContent = linkLabel;
          el.appendChild(msg);
          el.appendChild(link);
          el.style.display = "block";
        }

        function renderEngineBadge() {
          const map = {
            none: "Idle",
            mubert: "Mubert",
            elevenlabs: "ElevenLabs fallback",
          };
          const label = map[activeEngine] || "Unknown";
          $("engineBadge").textContent = `Engine: ${label}`;
        }

        function render() {
          // palette preview
          $("p1").style.background = state.enabled[0] ? state.palette[0] : "#1b1b1b";
          $("p2").style.background = state.enabled[1] ? state.palette[1] : "#1b1b1b";
          $("p3").style.background = state.enabled[2] ? state.palette[2] : "#1b1b1b";
          const widths = deriveNormalizedRoleWeights();
          $("p1").style.width = `${widths[0]}%`;
          $("p2").style.width = `${widths[1]}%`;
          $("p3").style.width = `${widths[2]}%`;

          const activePalette = deriveActivePalette();
          const mapped = activePalette.length ? deriveCombinedParams() : null;
          if (mapped?.combined) {
            visualizerEnergy = mapped.combined.energy;
          }

          const payload = {
            palette: activePalette,
            params: mapped?.combined ?? { energy: 0, texture: 0, space: 0 },
            color_params: mapped?.perColor ?? [],
            playlist_index: "ambient-auto",
            custom_id: getOrCreateCustomId(),
          };
          $("payload").textContent = JSON.stringify(payload, null, 2);
        }

        function readFromUI() {
          render();
        }

        let liveTimer = null;
        let playbackSession = 0;
        let activeEngine = "none"; // "none" | "mubert" | "elevenlabs"
        let currentObjectUrl = null;
        let elevenAbortController = null;
        let fallbackInProgress = false;
        let lastPayload = null;
        let elevenTimeUpdateHandler = null;
        let elevenMetadataHandler = null;
        let elevenLoopRafId = 0;
        let elevenLoopStart = 0;
        let elevenLoopEnd = 0;
        const ELEVEN_LOOP_MARGIN_SECONDS = 1.2;
        const ELEVEN_MIN_LOOP_WINDOW_SECONDS = 6;
        const ELEVEN_LOOP_GUARD_SECONDS = 0.08;
        const CROSSFADE_MS = 1400;

        const players = [$("player"), $("playerB")];
        let activePlayer = players[0];
        let standbyPlayer = players[1];
        let elevenLoopDeck = null;

        function syncPlayerVisibility() {
          activePlayer.style.display = "";
          standbyPlayer.style.display = "none";
        }

        function swapPlayers() {
          const prev = activePlayer;
          activePlayer = standbyPlayer;
          standbyPlayer = prev;
          syncPlayerVisibility();
        }

        function isAudible(player) {
          return !!player && !player.paused && !!player.currentSrc;
        }

        function hardStopPlayer(player) {
          try {
            player.pause();
            player.onended = null;
            player.loop = false;
            player.volume = 1;
            player.removeAttribute("src");
            player.load();
          } catch {}
        }

        function stopAllPlayers() {
          hardStopPlayer(players[0]);
          hardStopPlayer(players[1]);
        }

        async function waitForDeckReady(player, timeoutMs = 10000) {
          if (player.readyState >= 2) return "ready";
          return await new Promise((resolve, reject) => {
            const t = window.setTimeout(() => done(null, "timeout"), timeoutMs);
            const onCanPlay = () => done();
            const onError = () => done(new Error("Audio load error"));

            function done(err, mode = "ready") {
              window.clearTimeout(t);
              player.removeEventListener("canplay", onCanPlay);
              player.removeEventListener("error", onError);
              if (err) reject(err);
              else resolve(mode);
            }

            player.addEventListener("canplay", onCanPlay, { once: true });
            player.addEventListener("error", onError, { once: true });
          });
        }

        async function crossfadePlayers(fromPlayer, toPlayer, durationMs = CROSSFADE_MS) {
          const start = performance.now();
          fromPlayer.volume = 1;
          toPlayer.volume = 0;

          await new Promise((resolve) => {
            const tick = (now) => {
              const t = Math.min(1, (now - start) / durationMs);
              fromPlayer.volume = 1 - t;
              toPlayer.volume = t;
              if (t >= 1) resolve();
              else requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          });

          fromPlayer.volume = 1;
          toPlayer.volume = 1;
        }

        function buildPayload() {
          const activePalette = deriveActivePalette();
          if (!activePalette.length) {
            return {
              palette: [],
              params: { energy: 0, texture: 0, space: 0 },
              color_params: [],
              playlist_index: "ambient-auto",
              custom_id: getOrCreateCustomId(),
            };
          }
          const mapped = deriveCombinedParams();
          return {
            palette: activePalette,
            params: mapped.combined,
            color_params: mapped.perColor,
            playlist_index: "ambient-auto",
            custom_id: getOrCreateCustomId(),
          };
        }

        function releaseObjectUrl(url) {
          if (!url) return;
          try {
            URL.revokeObjectURL(url);
          } catch {}
        }

        function resetElevenState() {
          detachElevenLoopWindow();
          if (elevenAbortController) {
            try {
              elevenAbortController.abort();
            } catch {}
          }
          elevenAbortController = null;
          releaseObjectUrl(currentObjectUrl);
          currentObjectUrl = null;
        }

        function detachElevenLoopWindow() {
          const player = elevenLoopDeck;
          if (!player) return;
          if (elevenMetadataHandler) {
            player.removeEventListener("loadedmetadata", elevenMetadataHandler);
            elevenMetadataHandler = null;
          }
          if (elevenTimeUpdateHandler) {
            player.removeEventListener("timeupdate", elevenTimeUpdateHandler);
            elevenTimeUpdateHandler = null;
          }
          if (elevenLoopRafId) {
            cancelAnimationFrame(elevenLoopRafId);
            elevenLoopRafId = 0;
          }
          player.loop = false;
          elevenLoopStart = 0;
          elevenLoopEnd = 0;
          elevenLoopDeck = null;
        }

        function attachElevenLoopWindow(player) {
          detachElevenLoopWindow();
          elevenLoopDeck = player;

          elevenMetadataHandler = () => {
            const duration = Number(player.duration || 0);
            if (!Number.isFinite(duration) || duration <= 0) return;

            const margin = Math.min(ELEVEN_LOOP_MARGIN_SECONDS, duration * 0.2);
            const start = margin;
            const end = Math.max(start, duration - margin);
            if (end - start < ELEVEN_MIN_LOOP_WINDOW_SECONDS) {
              // Fallback to native loop for very short clips.
              player.loop = true;
              return;
            }

            elevenLoopStart = start;
            elevenLoopEnd = end;

            if (player.currentTime < elevenLoopStart || player.currentTime >= elevenLoopEnd) {
              player.currentTime = elevenLoopStart;
            }
          };

          elevenTimeUpdateHandler = () => {
            if (!elevenLoopEnd || !elevenLoopStart) return;
            if (player.currentTime >= elevenLoopEnd - ELEVEN_LOOP_GUARD_SECONDS) {
              player.currentTime = elevenLoopStart;
            }
          };

          const tick = () => {
            if (activeEngine !== "elevenlabs" || elevenLoopDeck !== player) {
              elevenLoopRafId = 0;
              return;
            }
            if (elevenLoopEnd && elevenLoopStart) {
              if (player.currentTime >= elevenLoopEnd - ELEVEN_LOOP_GUARD_SECONDS) {
                player.currentTime = elevenLoopStart;
              }
            }
            elevenLoopRafId = requestAnimationFrame(tick);
          };

          player.addEventListener("loadedmetadata", elevenMetadataHandler);
          player.addEventListener("timeupdate", elevenTimeUpdateHandler);
          elevenLoopRafId = requestAnimationFrame(tick);
        }

        async function transitionToUrl(url, { crossfade = true, prepareTarget = null, finalize = null } = {}) {
          const hasActiveAudio = isAudible(activePlayer);
          const target = hasActiveAudio ? standbyPlayer : activePlayer;
          const source = hasActiveAudio ? activePlayer : null;

          // Prepare target deck while source keeps playing.
          hardStopPlayer(target);
          target.volume = hasActiveAudio && crossfade ? 0 : 1;
          if (prepareTarget) prepareTarget(target);
          target.src = url;
          target.load();

          const readyMode = await waitForDeckReady(target);
          if (readyMode === "timeout") {
            // Some streams become playable after canplay timeout; do not fail hard.
            setStatus("Stream is taking longer to buffer; continuing…");
          }
          try {
            await target.play();
          } catch (err) {
            const e = new Error(`Deck play failed: ${err?.message || String(err)}`);
            e.isTransitionPlayError = true;
            e.originalError = err;
            throw e;
          }

          if (!source || !crossfade) {
            if (target !== activePlayer) swapPlayers();
            if (finalize) finalize(activePlayer);
            return;
          }

          await crossfadePlayers(source, target, CROSSFADE_MS);
          hardStopPlayer(source);
          swapPlayers();
          if (finalize) finalize(activePlayer);
        }

        async function switchToElevenFallback(payload, reasonText, { preserveNotice = false } = {}) {
          if (!payload) return;
          if (fallbackInProgress) return;
          if (activeEngine === "elevenlabs") return;
          fallbackInProgress = true;

          const sessionId = ++playbackSession;

          try {
            activeEngine = "elevenlabs";
            renderEngineBadge();
            resetElevenState();
            if (!preserveNotice) clearNotice();
            setStatus(`${reasonText} Switching to ElevenLabs fallback…`);
            await playElevenLoop(sessionId, payload);
          } catch (fallbackErr) {
            console.error(fallbackErr);
            const name = fallbackErr?.name || "Error";
            const msg = fallbackErr?.message || String(fallbackErr);
            if (fallbackErr?.code === "insufficient_credits") {
              showNoticeWithLink(
                "ElevenLabs mangler credits til at generere musik.",
                "https://elevenlabs.io/app/subscription",
                "Tank op / opgrader hos ElevenLabs"
              );
            }
            setStatus(`Fallback error (${name}): ${msg}`);
          } finally {
            fallbackInProgress = false;
          }
        }

        // Audio diagnostics (active deck only can trigger fallback)
        (() => {
          for (const player of players) {
            player.addEventListener("error", () => {
              const code = player.error?.code;
              const info = `Audio error event. mediaError=${code ?? "none"} net=${player.networkState} ready=${player.readyState}`;
              setStatus(info);

              if (activeEngine === "mubert" && player === activePlayer) {
                const payload = lastPayload || buildPayload();
                switchToElevenFallback(payload, `${info}.`);
              }
            });
          }
        })();

        function isMubertAuthFailure(status, bodyText) {
          if (status === 401) return true;
          const text = String(bodyText || "");
          return /Unauthenticated|service\/customers 401|streaming\/get-link 401|API 401/i.test(text);
        }

        function isMubertQuotaFailure(message) {
          const text = String(message || "");
          return /LicenseLimitStreamingDuration|Streaming duration limit exceeded|streaming_duration_limit/i.test(text);
        }

        async function fetchMubertUrl(payload) {
          const res = await fetch("/api/mubert", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (!res.ok) {
            const text = await res.text().catch(() => "");
            const err = new Error(`API ${res.status}: ${text}`);
            err.isMubertAuthFailure = isMubertAuthFailure(res.status, text);
            throw err;
          }

          const json = await res.json();
          const proxyUrl = json?.proxyUrl;
          const streamUrl = json?.streamUrl;
          const urlToPlay = proxyUrl || streamUrl;
          if (!urlToPlay) throw new Error("Missing proxyUrl/streamUrl from /api/mubert");
          return {
            url: String(urlToPlay),
            intensity: String(json?.intensity || "unknown"),
            blendedIntensity: Number(json?.blendedIntensity ?? NaN),
            paletteProfile: String(json?.paletteProfile?.name || "unknown"),
            playlistIndex: String(json?.playlistIndex || "unknown"),
            playlistLabel: String(json?.playlistLabel || "unknown"),
          };
        }

        async function fetchElevenSegmentUrl(payload, signal) {
          const res = await fetch("/api/music", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              palette: payload.palette,
              params: payload.params,
            }),
            signal,
          });

          if (!res.ok) {
            const text = await res.text().catch(() => "");
            const err = new Error(`ElevenLabs fallback ${res.status}: ${text}`);
            err.code = /insufficient_credits|quota_exceeded|payment_required/i.test(text)
              ? "insufficient_credits"
              : "eleven_error";
            throw err;
          }

          const blob = await res.blob();
          return URL.createObjectURL(blob);
        }

        async function playElevenLoop(sessionId, payload) {
          elevenAbortController = new AbortController();

          const firstUrl = await fetchElevenSegmentUrl(payload, elevenAbortController.signal);
          if (sessionId !== playbackSession || activeEngine !== "elevenlabs") {
            releaseObjectUrl(firstUrl);
            return;
          }

          const previousObjectUrl = currentObjectUrl;
          currentObjectUrl = firstUrl;
          await transitionToUrl(firstUrl, {
            crossfade: true,
            prepareTarget: (target) => {
              attachElevenLoopWindow(target);
            },
          });
          releaseObjectUrl(previousObjectUrl);
          setStatus("Playing via ElevenLabs fallback (seamless loop mode).");
        }

        async function startPlayback({ reason = "manual" } = {}) {
          readFromUI();
          const payload = buildPayload();
          if (!payload.palette.length) {
            stopPlayback();
            setStatus("All colours are off. No music is generated.");
            return;
          }
          lastPayload = payload;
          const sessionId = ++playbackSession;
          const label = reason === "manual" ? "Starting stream…" : "Updating stream…";
          clearNotice();
          setStatus(label);
          setVisualizerBusy(true);

          try {
            const mubert = await fetchMubertUrl(payload);
            if (sessionId !== playbackSession) return;

            const preview = String(mubert.url).slice(0, 90) + (String(mubert.url).length > 90 ? "…" : "");
            detachElevenLoopWindow();
            await transitionToUrl(mubert.url, {
              crossfade: true,
              prepareTarget: (target) => {
                target.loop = false;
              },
            });
            releaseObjectUrl(currentObjectUrl);
            currentObjectUrl = null;
            activeEngine = "mubert";
            renderEngineBadge();
            const mapped =
              Number.isFinite(mubert.blendedIntensity)
                ? `preset=${mubert.playlistLabel} (${mubert.playlistIndex}), profile=${mubert.paletteProfile}, intensity=${mubert.intensity} (${mubert.blendedIntensity})`
                : `intensity=${mubert.intensity}`;
            if (Number.isFinite(mubert.blendedIntensity)) {
              visualizerEnergy = clamp(mubert.blendedIntensity, 0, 100);
            } else if (payload?.params?.energy != null) {
              visualizerEnergy = clamp(Number(payload.params.energy), 0, 100);
            }
            visualizerIntensityTier = String(mubert.intensity || "low");
            setStatus(`Playing via Mubert (${mapped}). ${preview}`);
          } catch (err) {
            if (sessionId !== playbackSession) return;

            if (isMubertQuotaFailure(err?.message || "")) {
              showNoticeWithLink(
                "Mubert monthly streaming limit is reached for this license.",
                "https://mubert.com/business",
                "Open Mubert plan / billing"
              );
              await switchToElevenFallback(payload, "Mubert quota reached.", { preserveNotice: true });
              return;
            }

            if (err?.isTransitionPlayError) {
              // Keep current audio running; this can happen on transient deck-load races in Safari.
              const msg = err?.originalError?.message || err?.message || String(err);
              setStatus(`Update delayed: ${msg}. Current stream continues.`);
              return;
            }

            const isAuth = !!err?.isMubertAuthFailure;
            const canFallbackFromPlayback = activeEngine === "mubert";
            if (!isAuth && !canFallbackFromPlayback) {
              console.error(err);
              const name = err?.name || "Error";
              const msg = err?.message || String(err);
              setStatus(`Error (${name}): ${msg}`);
              return;
            }

            const reason = isAuth
              ? "Mubert auth failed (401)."
              : "Mubert playback failed.";
            console.warn(`${reason} Switching to ElevenLabs fallback`, err);
            await switchToElevenFallback(payload, reason);
          } finally {
            setVisualizerBusy(false);
          }
        }

        function scheduleLiveUpdate() {
          if (liveTimer) window.clearTimeout(liveTimer);
          liveTimer = window.setTimeout(() => {
            liveTimer = null;
            startPlayback({ reason: "live" });
          }, 700);
        }

        function stopPlayback() {
          if (liveTimer) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }

          stopAllPlayers();
          activeEngine = "none";
          renderEngineBadge();
          resetElevenState();
          fallbackInProgress = false;
          clearNotice();
          visualizerBusyCount = 0;
          wheel.spinner.classList.remove("on");

          setStatus("Stopped.");
        }

        // --- wire up UI ---
        function attachWheelInteractions() {
          wheel.dots.forEach((dot, idx) => {
            dot.addEventListener("mousedown", (e) => {
              e.preventDefault();
              hideHexPopup();
              wheel.dragIndex = idx;
            });

            dot.addEventListener("dblclick", (e) => {
              e.preventDefault();
              state.enabled[idx] = !state.enabled[idx];
              updateDotVisuals();
              render();
              scheduleLiveUpdate();
            });

            dot.addEventListener("contextmenu", (e) => {
              e.preventDefault();
              openHexPopup(idx, e.clientX, e.clientY);
            });
          });

          window.addEventListener("mousemove", (e) => {
            if (wheel.dragIndex < 0) return;
            const hs = pointerToHueSat(e.clientX, e.clientY);
            commitRoleColor(wheel.dragIndex, hs, { triggerUpdate: false });
          });

          window.addEventListener("mouseup", () => {
            if (wheel.dragIndex < 0) return;
            wheel.dragIndex = -1;
            scheduleLiveUpdate();
          });

          wheel.popupInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
              const idx = wheel.editIndex;
              const v = normalizeHex(wheel.popupInput.value);
              if (idx >= 0 && v) {
                const rgb = hexToRgb(v);
                if (rgb) {
                  const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
                  const vv = clamp(hsv.v / 100, 0, 1);
                  const sat = 1 - Math.pow(vv, 1 / WHEEL_VALUE_GAMMA);
                  commitRoleColor(idx, { h: hsv.h, s: clamp(sat * 100, 0, 100) }, { triggerUpdate: true });
                }
              }
              hideHexPopup();
            } else if (e.key === "Escape") {
              hideHexPopup();
            }
          });

          window.addEventListener("mousedown", (e) => {
            if (wheel.popup.style.display !== "block") return;
            if (wheel.popup.contains(e.target)) return;
            hideHexPopup();
          });

          window.addEventListener("resize", () => {
            drawWheel();
            updateDotVisuals();
            resizeVisualizerCanvas();
          });

          const ro = new ResizeObserver(() => {
            drawWheel();
            updateDotVisuals();
            resizeVisualizerCanvas();
          });
          ro.observe(wheel.stage);
        }

        $("generate").addEventListener("click", () => startPlayback({ reason: "manual" }));
        $("stop").addEventListener("click", stopPlayback);
        $("payloadToggleBtn").addEventListener("click", () => {
          const panel = $("payloadPanel");
          const hidden = !panel.hidden;
          panel.hidden = hidden;
          $("payloadToggleBtn").setAttribute("aria-pressed", hidden ? "true" : "false");
        });

        // initial
        syncPlayerVisibility();
        activePlayer.volume = 1;
        standbyPlayer.volume = 1;
        initWheelFromState();
        drawWheel();
        resizeVisualizerCanvas();
        startVisualizerLoop();
        updateDotVisuals();
        attachWheelInteractions();
        readFromUI();
        renderEngineBadge();
        setStatus("Ready.");
      </script>
    </main>
  </body>
</html>
